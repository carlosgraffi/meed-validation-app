# SQLite database file. On Railway, mount a volume at /data and set DATABASE_URL="file:/data/meed.db"
DATABASE_URL="file:./meed.db"

# Secret for NextAuth JWT signing. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-in-production"
NEXTAUTH_URL="http://localhost:3000"

# Admin email (single hardcoded admin). Logging in with this email reveals admin dashboard.
ADMIN_EMAIL="carlos.graffi@gmail.com"

# Token TTL for magic links (minutes)
MAGIC_LINK_TTL_MIN=10080
