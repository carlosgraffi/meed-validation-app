# SQLite database file. On Railway, mount a volume at /data and set DATABASE_URL="file:/data/meed.db"
DATABASE_URL="file:./meed.db"

# Secret for NextAuth JWT signing. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-in-production"
NEXTAUTH_URL="http://localhost:3000"

# Admin email (single hardcoded admin). Logging in with this email reveals admin dashboard.
ADMIN_EMAIL="carlos.graffi@gmail.com"

# Admin password — for the /admin/login URL. Set a strong value in production.
# If unset, the password login form is disabled and admin must use a magic link.
ADMIN_PASSWORD="changeme-pick-a-strong-password"

# Demo expert password — for the /demo/login URL. Logs in as a sandbox expert
# whose evaluations are excluded from CORFO metrics and the export. Leave unset
# in production if you don't want demo access exposed.
DEMO_PASSWORD="changeme-demo-password"

# Token TTL for magic links (minutes)
MAGIC_LINK_TTL_MIN=10080
